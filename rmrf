#!/bin/bash

if [ -n "$DEBUG" ]; then
    PS4=':${LINENO}+'
    set -x
fi

SUDO=""
TIMESTAMP=$(date --iso-8601=seconds)
TARBALL="$TIMESTAMP.tar.gz"
SCRIPT_NAME="$(basename "$(test -L "$0" && readlink "$0" || echo "$0")")"
TARGET_NAME="$(basename "$0")"
RMRF_CFG=~/.config/rmrf/rmrf.cfg
BKUP_CFG=~/.config/bkup/bkup.cfg

#FIXME: this should be removed later
RMRF_CFG=$(basename $RMRF_CFG)
BKUP_CFG=$(basename $BKUP_CFG)

[ -f "$RMRF_CFG" ] && source <(grep = $RMRF_CFG | sed 's/ *= */=/g')
[ -f "$BKUP_CFG" ] && source <(grep = $BKUP_CFG | sed 's/ *= */=/g')

FILES=()
for FILE in "${@}"; do
    FILES+=("$(realpath "$FILE")")
done

echo "SCRIPT_NAME=$SCRIPT_NAME, TARGET_NAME=$TARGET_NAME"
echo "RMRF_PATH=$RMRF_PATH, RMRF_SUDO=$RMRF_SUDO, RMRF_KEEP=$RMRF_KEEP"
echo "BKUP_PATH=$BKUP_PATH, BKUP_SUDO=$BKUP_SUDO"

usage() {
    echo "usage"
}

do_bkup() {
    BKUP_PATH="$1"
    [ "$BKUP_SUDO" == "yes" ] && SUDO=sudo
    echo "do_bkup: BKUP_PATH=$BKUP_PATH"
    mkdir -p "$BKUP_PATH"
    "$SUDO" tar --force-local --absolute-names --preserve-permissions --create --verbose --gzip --file "$TARBALL" "${FILES[@]}"
    "$SUDO" mv "$TARBALL" "$BKUP_PATH"
    echo "-> $BKUP_PATH/$TARBALL"
}

do_rmrf() {
    RMRF_PATH="$1"
    [ "$RMRF_SUDO" == "yes" ] && SUDO=sudo
    echo "do_rmrf: RMRF_PATH=$RMRF_PATH"
    do_bkup "$RMRF_PATH"
    DELETED=$(find "$RMRF_PATH" -mtime "+$RMRF_KEEP")
    if [ -n "$DELETED" ]; then
        echo "$DELETED"
        echo "-> /dev/null"
    fi
    "$SUDO" find "$RMRF_PATH" -mtime "+$RMRF_KEEP" -delete
    "$SUDO" rm -rf "${FILES[@]}"
}

do_list() {
    LIST_PATH="$1"
    echo "do_list: LIST_PATH=$LIST_PATH"
    for TARBALL in "$LIST_PATH/"*; do
        echo "TARBALL=$TARBALL"
        sudo tar --absolute-names -tvf "$TARBALL" | grep -v ^d | sed 's/^/  /'
    done
    exit 0
}

case "$TARGET_NAME" in
    bkup)
        do_bkup "$BKUP_PATH"
        ;;
    rmrf)
        do_rmrf "$RMRF_PATH"
        ;;
    ls-bkup)
        do_list "$BKUP_PATH"
        ;;
    ls-rmrf)
        do_list "$RMRF_PATH"
        ;;
    *)
        usage
        ;;
esac
